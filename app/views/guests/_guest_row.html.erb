<tr id="guest-<%= guest.id %>" class="guest-row-new" data-added-by="<%= guest.added_by_id %>">
  <td>
    <span class="fw-normal"><%= guest.name %></span><br>
    <code class="text-gold" style="font-size:0.7rem;"><%= guest.token %></code>
  </td>

  <% w = wedding || guest.wedding %>
  <% if w.has_partner? %>
    <td>
      <% adder = guest.added_by %>
      <% if adder %>
        <span class="added-by-badge <%= adder.id == w.user_id ? 'added-by-badge--owner' : 'added-by-badge--partner' %>">
          <%= defined?(current_user) && adder.id == current_user&.id ? "You" : adder.name.split.first %>
        </span>
      <% end %>
    </td>
  <% end %>

  <td class="text-muted small"><%= guest.phone %></td>
  <td>
    <% status = guest.rsvp&.status || "pending" %>
    <span class="status-badge badge-<%= status %>"><%= status.capitalize %></span>
  </td>
  <td>
    <% unless guest.rsvp %>
      <%= link_to whatsapp_invite_url(guest, w),
            target: "_blank", rel: "noopener",
            class: "btn btn-sm btn-whatsapp-icon #{ guest.invitation_sent_at ? 'btn-whatsapp-icon--sent' : '' }",
            title: guest.invitation_sent_at ? "Sent #{time_ago_in_words(guest.invitation_sent_at)} ago — click to resend" : "Send invitation via WhatsApp" do %>
        <span class="d-inline-flex align-items-center gap-1">
          <%= image_tag "whatsapp-logo.png", alt: "WhatsApp", style: "width:15px;height:15px;flex-shrink:0;" %>
          <span><%= guest.invitation_sent_at ? "Resend" : "Send" %></span>
        </span>
      <% end %>
    <% else %>
      <span class="text-muted small fst-italic">Responded</span>
    <% end %>
  </td>
  <td class="text-end">
    <div class="d-flex align-items-center justify-content-end gap-2">
      <% unless guest.invitation_sent_at %>
        <%= button_to mark_sent_guest_path(guest), method: :patch,
              class: "btn btn-sm btn-outline-secondary",
              title: "Mark as sent without opening WhatsApp" do %>
          ✓
        <% end %>
      <% end %>
      <%# Only show delete if owner or added this guest themselves %>
      <% can_delete = defined?(current_user) && (w.owner?(current_user) || guest.added_by_id == current_user&.id) %>
      <% if can_delete %>
        <%= button_to guest_path(guest), method: :delete,
              class: "btn btn-sm btn-link text-muted p-0",
              data: { turbo_confirm: "Remove #{guest.name} from the guest list?" } do %>
          &times;
        <% end %>
      <% end %>
    </div>
  </td>
</tr>
