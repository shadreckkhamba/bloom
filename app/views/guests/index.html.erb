<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
      <h1 style="font-size:2rem;" class="mb-0">Guest List</h1>
      <p class="text-muted small mb-0"><%= @wedding.couple_names %></p>
    </div>
    <%= link_to "← Dashboard", dashboard_path, class: "btn btn-bloom-outline btn-sm" %>
  </div>

  <!-- Import row -->
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <div class="auth-card">
        <h6 class="text-muted mb-3" style="letter-spacing:0.08em;text-transform:uppercase;font-size:0.75rem;">Import CSV</h6>
        <%= form_with url: import_guests_path, multipart: true do |f| %>
          <div class="input-group">
            <%= f.file_field :file, accept: ".csv", class: "form-control form-control-sm" %>
            <%= f.submit "Import", class: "btn btn-bloom btn-sm" %>
          </div>
          <p class="text-muted mt-1" style="font-size:0.72rem;">
            CSV columns: <code>Name</code>, <code>Phone</code> &nbsp;·&nbsp;
            Phone format: <code>0999123456</code>
          </p>
        <% end %>
      </div>
    </div>
    <div class="col-md-6">
      <div class="auth-card h-100 d-flex flex-column justify-content-center">
        <p class="small text-muted mb-1">
          <strong><%= @guests.count { |g| g.invitation_sent_at.nil? }</strong> guests haven't been sent an invitation yet.
        </p>
        <p class="text-muted mb-0" style="font-size:0.78rem;">
          Click 📲 next to each guest to open WhatsApp with their personal message pre-filled.
          Mark them sent once done.
        </p>
      </div>
    </div>
  </div>

  <!-- Guest table -->
  <% if @guests.any? %>
    <div class="table-responsive">
      <table class="table guest-table align-middle">
        <thead>
          <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Invite</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @guests.each do |guest| %>
            <tr>
              <td>
                <%= guest.name %>
                <br>
                <code class="text-gold" style="font-size:0.72rem;"><%= guest.token %></code>
              </td>
              <td class="text-muted small"><%= guest.phone %></td>
              <td>
                <% status = guest.rsvp&.status || "pending" %>
                <span class="status-badge badge-<%= status %>"><%= status.capitalize %></span>
              </td>
              <td>
                <!-- WhatsApp Click-to-Chat -->
                <%= link_to whatsapp_invite_url(guest, @wedding),
                      target: "_blank", rel: "noopener",
                      class: "btn btn-sm #{ guest.invitation_sent_at ? 'btn-outline-secondary' : 'btn-whatsapp' }",
                      title: guest.invitation_sent_at ? "Sent #{time_ago_in_words(guest.invitation_sent_at)} ago" : "Send invitation" do %>
                  📲 <%= guest.invitation_sent_at ? "Resend" : "Send" %>
                <% end %>

                <% unless guest.invitation_sent_at %>
                  &nbsp;
                  <%= button_to "✓ Mark sent", mark_sent_guest_path(guest),
                        method: :patch,
                        class: "btn btn-sm btn-outline-secondary",
                        title: "Mark as sent without opening WhatsApp" %>
                <% end %>
              </td>
              <td class="text-end">
                <%= button_to "×", guest_path(guest), method: :delete,
                      class: "btn btn-sm btn-link text-muted p-0",
                      data: { turbo_confirm: "Remove #{guest.name}?" } %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <p class="mb-3">No guests yet.</p>
      <p class="small">Upload a CSV above to get started.</p>
    </div>
  <% end %>

</div>
