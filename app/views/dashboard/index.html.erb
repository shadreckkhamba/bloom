<div class="container py-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-start mb-5 flex-wrap gap-3">
    <div class="d-flex align-items-center gap-3">
      <%= image_tag "wedding.png", alt: "Wedding", style: "width:64px;height:64px;object-fit:contain;flex-shrink:0;" %>
      <div>
        <h1 style="font-size:2.2rem;" class="mb-1"><%= @wedding.couple_names %></h1>
        <p class="text-muted mb-0">
          <%= @wedding.venue %> &nbsp;·&nbsp;
          <%= @wedding.wedding_date.strftime("%B %d, %Y") %>
          <% if @wedding.days_until > 0 %>
            &nbsp;·&nbsp; <span class="text-gold"><%= @wedding.days_until %> days to go</span>
          <% end %>
        </p>
      </div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <% if wedding_owner? %>
        <%= link_to "Edit details", edit_wedding_path, class: "btn btn-bloom-outline btn-sm" %>
        <%= link_to "Partner 🔗", partner_invite_path, class: "btn btn-bloom-outline btn-sm" %>
      <% end %>
      <%= link_to "Messages 💌", messages_path, class: "btn btn-bloom-outline btn-sm" %>
      <%= link_to "Manage guests", guests_path, class: "btn btn-bloom btn-sm" %>
    </div>
  </div>

  <!-- Shared link warning -->
  <% if @flagged.any? %>
    <div class="alert-shared mb-4">
      <span style="font-size:1.1rem;">⚠️</span>
      <div>
        <strong>Possible shared links detected</strong> —
        <%= @flagged.count %> invitation#{"s" if @flagged.count != 1} were opened from more than one device:
        <span class="text-muted"><%= @flagged.map(&:name).join(", ") %></span>.
        Someone may have forwarded their link.
      </div>
    </div>
  <% end %>

  <!-- Combined stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-number"><%= @total %></div>
        <div class="stat-label">Invited</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-number text-success"><%= @accepted %></div>
        <div class="stat-label">Accepted</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-number" style="color:#dc3545;"><%= @declined %></div>
        <div class="stat-label">Declined</div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stat-card">
        <div class="stat-number" style="color:#b8973f;"><%= @pending %></div>
        <div class="stat-label">Pending</div>
      </div>
    </div>
  </div>

  <!-- Seat limit bar -->
  <% if @seat_limit.present? %>
    <% pct = [(@accepted.to_f / @seat_limit * 100).round, 100].min %>
    <% low = @seats_remaining && @seats_remaining < 10 %>
    <div class="auth-card mb-4 py-3">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <span class="small text-muted" style="letter-spacing:0.06em;text-transform:uppercase;font-size:0.72rem;">Seats</span>
        <span class="small <%= low ? 'text-danger fw-normal' : 'text-muted' %>">
          <%= @accepted %> confirmed of <%= @seat_limit %>
          <% if @seats_remaining %>
            &nbsp;·&nbsp; <strong><%= @seats_remaining %></strong> remaining
            <%= "⚠️" if low %>
          <% end %>
        </span>
      </div>
      <div class="progress" style="height:6px;border-radius:50px;">
        <div class="progress-bar <%= low ? 'bg-danger' : '' %>"
             role="progressbar"
             style="width:<%= pct %>%;background:<%= low ? '' : 'var(--primary)' %>;"
             aria-valuenow="<%= pct %>" aria-valuemin="0" aria-valuemax="100"></div>
      </div>
    </div>
  <% end %>

  <!-- Per-partner split panel -->
  <% if @partner_stats %>
    <%
      my_stats    = current_user.id == @wedding.user_id ? @owner_stats  : @partner_stats
      their_stats = current_user.id == @wedding.user_id ? @partner_stats : @owner_stats
      their_name  = their_stats[:user].name.split.first
      my_role     = @wedding.role_for(current_user)
      their_role  = @wedding.role_for(their_stats[:user])
      my_icon     = my_role    == :bride ? "woman.png" : "man.png"
      their_icon  = their_role == :bride ? "woman.png" : "man.png"
    %>
    <div class="row g-3 mb-5">
      <div class="col-md-6">
        <div class="partner-panel partner-panel--owner">
          <div class="partner-panel-label">
            <%= image_tag my_icon, alt: "", style: "width:22px;height:22px;object-fit:contain;vertical-align:middle;margin-right:6px;" %>
            Your guests
          </div>
          <div class="partner-panel-stats">
            <div class="partner-stat">
              <span class="partner-stat-num"><%= my_stats[:total] %></span>
              <span class="partner-stat-label">Invited</span>
            </div>
            <div class="partner-stat">
              <span class="partner-stat-num partner-stat-num--green"><%= my_stats[:accepted] %></span>
              <span class="partner-stat-label">Confirmed</span>
            </div>
            <div class="partner-stat">
              <span class="partner-stat-num partner-stat-num--muted"><%= my_stats[:not_sent] %></span>
              <span class="partner-stat-label">Not sent</span>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="partner-panel partner-panel--partner">
          <div class="partner-panel-label">
            <%= image_tag their_icon, alt: "", style: "width:22px;height:22px;object-fit:contain;vertical-align:middle;margin-right:6px;" %>
            <%= their_name %>'s guests
          </div>
          <div class="partner-panel-stats">
            <div class="partner-stat">
              <span class="partner-stat-num"><%= their_stats[:total] %></span>
              <span class="partner-stat-label">Invited</span>
            </div>
            <div class="partner-stat">
              <span class="partner-stat-num partner-stat-num--green"><%= their_stats[:accepted] %></span>
              <span class="partner-stat-label">Confirmed</span>
            </div>
            <div class="partner-stat">
              <span class="partner-stat-num partner-stat-num--muted"><%= their_stats[:not_sent] %></span>
              <span class="partner-stat-label">Not sent</span>
            </div>
          </div>
        </div>
      </div>
    </div>

  <% elsif wedding_owner? && !@wedding.has_partner? %>
    <!-- Connect partner nudge -->
    <div class="partner-connect-card mb-5">
      <span style="font-size:1.6rem;">🔗</span>
      <div class="flex-grow-1">
        <p class="mb-1 fw-normal">Invite your partner to manage guests separately</p>
        <p class="text-muted small mb-0">They get their own login and you'll both see the combined totals here.</p>
      </div>
      <%= link_to "Generate invite link →", partner_invite_path, class: "btn btn-bloom btn-sm flex-shrink-0" %>
    </div>
  <% else %>
    <div class="mb-5"></div>
  <% end %>

  <!-- Recent guests -->
  <% if @guests.any? %>
    <h2 class="mb-3" style="font-size:1.4rem;">Recent RSVPs</h2>
    <div class="table-responsive">
      <table class="table guest-table">
        <thead>
          <tr>
            <th>Guest</th>
            <th>Added by</th>
            <th>Status</th>
            <th>Seats</th>
            <th>Sent</th>
          </tr>
        </thead>
        <tbody>
          <% @guests.order(created_at: :desc).limit(10).each do |guest| %>
            <tr>
              <td><%= guest.name %></td>
              <td>
                <% adder = guest.added_by %>
                <% if adder %>
                  <span class="added-by-badge <%= adder.id == @wedding.user_id ? 'added-by-badge--owner' : 'added-by-badge--partner' %>">
                    <%= adder.id == current_user.id ? "You" : adder.name.split.first %>
                  </span>
                <% end %>
              </td>
              <td>
                <% status = guest.rsvp&.status || "pending" %>
                <span class="status-badge badge-<%= status %>"><%= status.capitalize %></span>
              </td>
              <td><%= guest.rsvp&.seats_reserved || "—" %></td>
              <td class="text-muted small">
                <%= guest.invitation_sent_at ? time_ago_in_words(guest.invitation_sent_at) + " ago" : "Not sent" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-3">
      <%= link_to "View all guests →", guests_path, class: "text-gold small" %>
      <span class="small text-muted">
        Total seats needed: &nbsp;<strong class="text-gold"><%= @total_seats %></strong>
      </span>
    </div>
  <% end %>

</div>
