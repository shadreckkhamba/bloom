<div class="auth-page">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-5 col-lg-4">
        <div class="text-center mb-4">
          <h1 class="text-gold" style="font-size:2rem;"><%= app_name %></h1>
          <p class="text-muted small">🌸 Private wedding invitations</p>
        </div>
        <div class="auth-card">
          <h2 class="mb-4" style="font-size:1.5rem;">Welcome back</h2>
          <%= form_with url: login_path, data: { turbo: false } do |f| %>
            <div class="mb-3">
              <%= f.label :email, "Email", class: "form-label small text-muted" %>
              <%= f.email_field :email, class: "form-control", autofocus: true, required: true %>
            </div>
            <div class="mb-4">
              <%= f.label :password, "Password", class: "form-label small text-muted" %>
              <%= f.password_field :password, class: "form-control", required: true %>
            </div>
            <%= f.submit "Sign in", class: "btn btn-bloom w-100" %>
          <% end %>
        </div>
        <p class="text-center mt-3 small text-muted">
          Don't have an account? <%= link_to "Create one", signup_path, class: "text-gold" %>
        </p>
      </div>
    </div>
  </div>
</div>
